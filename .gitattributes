# Normalize all text files to LF on commit
* text=auto eol=lf

# Force these to always be LF
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf
*.json   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.env*   text eol=lf

# Windows-only files can keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf